{
    "manifest_version": 3,
    "name": "Claude AI Exporter",
    "version": "1.0",
    "description": "Export the current claude.ai conversation to markdown and download the files generated by Claude.",
    "icons": {
        "16": "icons/icon-16.png",
        "32": "icons/icon-32.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },
    "action": {
        "default_title": "Export this claude.ai conversation",
        "default_icon": {
            "16": "icons/icon-16.png",
            "32": "icons/icon-32.png",
            "48": "icons/icon-48.png",
            "128": "icons/icon-128.png"
        }
    },
    "background": {
        "scripts": ["background.js"]
    },
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "claude-ai-exporter@ponceto.free.fr",
            "strict_min_version": "142.0",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    }
}
